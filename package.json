{
  "name": "hhuacm-dashboard",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.9",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @hhuacm-dashboard/db db:push",
    "db:studio": "turbo -F @hhuacm-dashboard/db db:studio",
    "db:generate": "turbo -F @hhuacm-dashboard/db db:generate",
    "db:migrate": "turbo -F @hhuacm-dashboard/db db:migrate",
    "db:local": "turbo -F @hhuacm-dashboard/db db:local",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@hhuacm-dashboard/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@hhuacm-dashboard/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.3"
  },
  "packageManager": "bun@1.3.13"
}
