{
  "name": "hhuacm-dashboard",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "17",
      "zod": "4",
      "typescript": "6",
      "@types/bun": "1",
      "hono": "4",
      "@trpc/server": "11",
      "better-auth": "1.6.9",
      "@heroui/react": "3.0.4",
      "@heroui/styles": "3.0.4",
      "lucide-react": "0.546",
      "react": "19",
      "react-dom": "19",
      "@trpc/client": "11",
      "@types/react": "19",
      "@types/react-dom": "19",
      "tailwindcss": "4"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types --output-logs=errors-only --ui=stream",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "test": "bun test --only-failures",
    "verify": "bun run fix && bun run check && bun run test",
    "db:push": "turbo -F @hhuacm-dashboard/db db:push",
    "db:studio": "turbo -F @hhuacm-dashboard/db db:studio",
    "db:generate": "turbo -F @hhuacm-dashboard/db db:generate",
    "db:migrate": "turbo -F @hhuacm-dashboard/db db:migrate",
    "db:local": "turbo -F @hhuacm-dashboard/db db:local",
    "check": "bun run check-types && bun x ultracite check",
    "fix": "ultracite fix",
    "import:ranklist-users": "bun run --cwd packages/auth import:ranklist-users"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@hhuacm-dashboard/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "turbo": "latest",
    "typescript": "catalog:",
    "ultracite": "latest"
  },
  "packageManager": "bun@1.3.13"
}
