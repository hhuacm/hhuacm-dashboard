{
  "name": "@hhuacm-dashboard/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-migrations": "drizzle-kit check",
    "check-types": "tsc --noEmit",
    "db:local": "turso dev --db-file local.db",
    "db:sync": "bun src/cli/db-sync.ts"
  },
  "dependencies": {
    "@hhuacm-dashboard/domain": "workspace:*",
    "@hhuacm-dashboard/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
