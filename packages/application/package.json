{
  "name": "@hhuacm-dashboard/application",
  "type": "module",
  "exports": {
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "system:grant-admin": "bun src/system/cli/set-user-role.ts --role admin",
    "system:import-users": "bun src/system/cli/import-users.ts",
    "system:revoke-admin": "bun src/system/cli/set-user-role.ts --role user"
  },
  "dependencies": {
    "@hhuacm-dashboard/db": "workspace:*",
    "@hhuacm-dashboard/domain": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hhuacm-dashboard/config": "workspace:*",
    "@libsql/client": "catalog:",
    "typescript": "catalog:"
  }
}
