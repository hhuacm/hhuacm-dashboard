# Docker Compose deployment settings.
IMAGE_TAG=local

# Default Compose mode expects an external reverse proxy such as host Nginx.
# These ports are bound to 127.0.0.1 on the Docker host.
WEB_HOST=127.0.0.1
WEB_PORT=3001
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# For local Docker-to-host Turso/libSQL, use:
# DATABASE_URL=http://host.docker.internal:8080
DATABASE_URL=http://host.docker.internal:8080
DATABASE_AUTH_TOKEN=

# Use a random value with at least 32 characters in production.
BETTER_AUTH_SECRET=change-me-to-a-random-secret-of-at-least-32-chars
BETTER_AUTH_URL=http://localhost
CORS_ORIGIN=http://localhost
